{
  "manifest_version": 3,
  "name": "WildcatReviews",
  "version": "1.0.0",
  "description": "Embeds Rate My Professors data into Davidson course schedule pages.",
  "icons": {
    "16": "icon/logo.png",
    "32": "icon/logo.png",
    "48": "icon/logo.png",
    "128": "icon/logo.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.ratemyprofessors.com/*",
    "https://course-schedule.davidson.edu/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://course-schedule.davidson.edu/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
